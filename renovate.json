{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Japan7/renovate-config",
    "github>Japan7/renovate-config:python"
  ],
  "packageRules": [
    {
      "matchManagers": ["pixi"],
      "matchDepNames": ["python"],
      "automerge": false
    },
    {
      "groupName": "Pytorch dependencies",
      "groupSlug": "pytorch",
      "matchDepNames": ["torch", "torchaudio", "torchcodec"]
    }
  ]
}
